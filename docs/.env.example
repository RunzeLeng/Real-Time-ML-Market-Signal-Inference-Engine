# Aurora DSQL
AURORA_DSQL_HOST=example-dsql.cluster-xxxxxxxxxxxx.us-east-1.dsql.amazonaws.com
AURORA_DSQL_DATABASE=postgres
AURORA_DSQL_USER=admin
AURORA_DSQL_REGION=us-east-1
AURORA_DSQL_PROFILE=default

# DynamoDB
DYNAMODB_REGION=us-east-1
DYNAMODB_PROCESSED_RECORDS_TABLE=processed_records_example
DYNAMODB_PUBLISHED_RECORDS_TABLE=published_records_example

# S3
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_NAME=example-project-bucket
AWS_S3_OBJECT_KEY_POST=post_data/example_posts.parquet
AWS_S3_OBJECT_KEY_ETF=market_data/example_etf.parquet
AWS_S3_OBJECT_KEY_GROUP_ETF=market_data/group_etf/
AWS_S3_OBJECT_KEY_SINGLE_ETF=market_data/single_etf/
AWS_S3_OBJECT_KEY_DAILY_NEWS=daily_news

# Aurora PostgreSQL / pgvector
AURORA_PGVECTOR_REGION=us-east-1
AURORA_PGVECTOR_HOST=example-pgvector.cluster-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
AURORA_PGVECTOR_PORT=5432
AURORA_PGVECTOR_DBNAME=postgres
AURORA_PGVECTOR_USER=admin
AURORA_PGVECTOR_SCHEMA=rag
AURORA_PGVECTOR_VECTOR_COLUMN=embedding_vector
AURORA_PGVECTOR_VECTOR_DIMENSION=1024

# Apify
APIFY_TOKEN=apify_api_example_token
APIFY_DEFAULT_ACTOR_ID=example_default_actor_id
APIFY_BACKUP_ACTOR_ID=example_backup_actor_id

# ScrapeOps
SCRAPEOPS_API_KEY=example-scrapeops-api-key
SCRAPEOPS_ENDPOINT=https://proxy.scrapeops.io/v1/
SCRAPEOPS_BASE_URL=https://example.com/api/v1/accounts/example/statuses

# SNS
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:xxxxxxxxxxxx:example-topic
AWS_SNS_REGION=us-east-1

# News ingestion
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
NEWS_API_TOKEN=example-news-api-token
NEWS_API_BASE_URL=https://api.thenewsapi.com/v1/news/all
NEWS_API_SEARCH_FIELDS=title,main_text
NEWS_API_LIMIT=25
NEWS_API_MAX_PAGES=20
NEWS_API_CATEGORIES=business,politics
NEWS_API_EXCLUDE_CATEGORIES=travel,food,entertainment,health,sports
NEWS_API_LANGUAGE=en
NEWS_API_LOCALE=us

# Topic memory
TOPIC_MEMORY_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
TOPIC_MEMORY_REGION=us-east-1
TOPIC_MATCHING_SYSTEM_PROMPT_PATH=src/prompt/text_to_topic_system_prompt.txt
TOPIC_SUMMARY_SYSTEM_PROMPT_PATH=src/prompt/topic_summary_system_prompt.txt
TOPIC_MATCHING_SCHEMA=training_data
TOPIC_MATCHING_TABLE=topic_matching
TOPIC_SUMMARY_SCHEMA=training_data
TOPIC_SUMMARY_TABLE=topic_summary

# Performance review
PERFORMANCE_REVIEW_DEFAULT_METRIC_COL=vwap_pct_change_30m
PERFORMANCE_REVIEW_SECONDARY_METRIC_COL=vwap_pct_change_3h
PERFORMANCE_REVIEW_REASONABLENESS_COL=reasonableness_score
PERFORMANCE_REVIEW_HIGH_REASONABLENESS_THRESHOLD=0.5
PERFORMANCE_REVIEW_LOOKBACK_DAYS=7
PERFORMANCE_REVIEW_REVIEW_WEEKDAY=0

# Alpaca
ALPACA_API_KEY=example-alpaca-api-key
ALPACA_SECRET_KEY=example-alpaca-secret-key

# AWS credentials for local development only
AWS_ACCESS_KEY=example-aws-access-key
AWS_SECRET_ACCESS_KEY=example-aws-secret-access-key

# RAG
RAG_TITAN_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
RAG_TITAN_EMBEDDING_REGION=us-east-1
RAG_TITAN_EMBEDDING_DIMENSION=1024
RAG_TITAN_EMBEDDING_NORMALIZE=true
RAG_CHUNK_MIN_TOKENS=200
RAG_CHUNK_MAX_TOKENS=380
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_EMBEDDING_MAX_WORKERS=3
RAG_EMBEDDING_MAX_ATTEMPTS=5
RAG_SCHEMA=rag
RAG_CHUNK_TABLE=chunked_df
RAG_EMBEDDING_TABLE=embedding_df

# Large language model
LLM_REGION=us-east-1
LLM_READ_TIMEOUT=300
LLM_CONNECT_TIMEOUT=60
LLM_MAX_RETRY_ATTEMPTS=3